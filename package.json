{
  "name": "flexgate-labs",
  "version": "1.0.0",
  "description": "Production-grade testing and simulation environment for FlexGate Proxy",
  "private": true,
  "scripts": {
    "infra:up": "podman-compose -f podman-compose.yml up -d --build",
    "infra:down": "podman-compose -f podman-compose.yml down -v",
    "infra:logs": "podman-compose -f podman-compose.yml logs -f",
    "infra:ps": "podman-compose -f podman-compose.yml ps",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --forceExit",
    "test:security": "jest --testPathPattern=tests/security --runInBand --forceExit",
    "test:chaos": "jest --testPathPattern=tests/chaos --runInBand --forceExit",
    "test:admin": "jest --testPathPattern=tests/admin --runInBand --forceExit",
    "test:observability": "jest --testPathPattern=tests/observability --runInBand --forceExit",
    "test:rate-limit": "jest --testPathPattern=tests/rate-limit --runInBand --forceExit",
    "test:circuit-breaker": "jest --testPathPattern=tests/circuit-breaker --runInBand --forceExit",
    "test:retry": "jest --testPathPattern=tests/retry --runInBand --forceExit",
    "test:timeout": "jest --testPathPattern=tests/timeout --runInBand --forceExit",
    "test:regression": "jest --testPathPattern=tests/regression --runInBand --forceExit",
    "test:load:baseline": "k6 run tests/load/baseline.k6.js",
    "test:load:spike": "k6 run tests/load/spike.k6.js",
    "test:load:stress": "k6 run tests/load/stress.k6.js",
    "test:load:soak": "k6 run tests/load/soak.k6.js",
    "test:load:autocannon": "ts-node tests/load/autocannon-baseline.ts",
    "seed": "ts-node scripts/seed-data.ts",
    "setup": "bash scripts/setup.sh",
    "teardown": "bash scripts/teardown.sh",
    "report": "jest --runInBand --forceExit --json --outputFile=reports/jest-results.json && ts-node scripts/generate-report.ts"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/node-fetch": "^2.6.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "undici": "^8.0.2"
  },
  "dependencies": {
    "autocannon": "^7.15.0",
    "axios": "^1.6.8",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nats": "^2.28.2",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "supertest": "^7.0.0",
    "uuid": "^9.0.1"
  }
}
